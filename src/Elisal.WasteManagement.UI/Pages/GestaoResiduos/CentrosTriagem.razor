@page "/gestao-residuos/centros"
@inject HttpClient Http
@using Elisal.WasteManagement.Application.DTOs
@inject NotificationService Notification

<PageTitle>SGR Elisal - Centros de Triagem</PageTitle>

<div class="p-6 lg:p-10 space-y-8 animate-fade-in">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6">
        <div>
            <h1 class="text-4xl font-black text-slate-900 dark:text-white leading-tight">
                Centros de <span class="text-gradient-green">Triagem</span>
            </h1>
            <p class="text-slate-500 font-medium mt-2">Gestão dos locais de processamento e separação de resíduos.</p>
        </div>
        <button @onclick="() => { _editCenter = new(); _modal = true; }" class="btn-vibrant px-8 py-3 flex items-center gap-2 shadow-green-glow">
            <span class="material-symbols-outlined font-bold">add_circle</span>
            NOVO CENTRO
        </button>
    </div>

    @* ── Cards dos Centros ── *@
    @if (centros == null)
    {
        <div class="flex justify-center py-20">
            <div class="size-8 border-2 border-primary border-t-transparent rounded-full animate-spin"></div>
        </div>
    }
    else if (!centros.Any())
    {
        <div class="bg-white dark:bg-slate-900 rounded-3xl p-20 text-center shadow-premium border border-slate-50 dark:border-slate-800">
            <span class="material-symbols-outlined text-slate-200 text-8xl font-light block mb-6">factory</span>
            <p class="text-slate-400 font-bold uppercase tracking-widest text-xs">Nenhum centro de triagem registado</p>
            <p class="text-slate-400 text-sm mt-2">Crie o primeiro centro para começar a receber resíduos.</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var c in centros)
            {
                <div class="bg-white dark:bg-slate-900 rounded-3xl p-6 shadow-premium border border-slate-50 dark:border-slate-800 hover:shadow-xl transition-all">
                    <div class="flex items-start justify-between mb-4">
                        <div class="size-12 rounded-2xl bg-primary/10 flex items-center justify-center">
                            <span class="material-symbols-outlined text-primary">factory</span>
                        </div>
                        <span class="px-3 py-1 rounded-lg text-[10px] font-black uppercase @(c.IsActive ? "bg-green-50 text-green-700" : "bg-red-50 text-red-700")">
                            @(c.IsActive ? "Activo" : "Inactivo")
                        </span>
                    </div>
                    <h3 class="text-lg font-black text-slate-900 dark:text-white">@c.Name</h3>
                    <p class="text-sm text-slate-500 mt-1">@c.Address</p>
                    <div class="mt-4 pt-4 border-t border-slate-100 dark:border-slate-800 grid grid-cols-2 gap-4">
                        <div>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Capacidade</p>
                            <p class="text-lg font-black text-slate-900 dark:text-white mt-1">@c.CapacityTonsPerDay.ToString("N1") <span class="text-xs text-slate-400">T/dia</span></p>
                        </div>
                        <div>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Município</p>
                            <p class="text-sm font-bold text-slate-600 dark:text-slate-300 mt-1">@c.Municipality</p>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(c.Contact))
                    {
                        <div class="mt-3 flex items-center gap-2 text-xs text-slate-500">
                            <span class="material-symbols-outlined text-sm">phone</span> @c.Contact
                        </div>
                    }
                    <button @onclick="() => EditCenter(c)" class="mt-4 w-full py-2 border border-slate-200 dark:border-slate-700 rounded-xl text-xs font-black text-slate-500 hover:border-primary hover:text-primary transition-all">
                        Editar
                    </button>
                </div>
            }
        </div>
    }
</div>

@* ── Modal ── *@
@if (_modal)
{
    <div class="fixed inset-0 z-[60] bg-slate-900/50 backdrop-blur-sm flex items-center justify-center p-4" @onclick="() => _modal = false">
        <div class="bg-white dark:bg-slate-900 rounded-3xl shadow-2xl w-full max-w-lg p-8 space-y-6" @onclick:stopPropagation="true">
            <h2 class="text-xl font-black text-slate-900 dark:text-white">@(_editId > 0 ? "Editar" : "Novo") Centro de Triagem</h2>
            <div class="space-y-4">
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Nome</label>
                    <input type="text" @bind="_editCenter.Name" class="w-full h-12 px-4 rounded-xl border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white font-bold" />
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Endereço</label>
                    <input type="text" @bind="_editCenter.Address" class="w-full h-12 px-4 rounded-xl border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white font-bold" />
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Município</label>
                        <input type="text" @bind="_editCenter.Municipality" class="w-full h-12 px-4 rounded-xl border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white font-bold" />
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Capacidade (T/dia)</label>
                        <input type="number" step="0.1" @bind="_editCenter.CapacityTonsPerDay" class="w-full h-12 px-4 rounded-xl border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white font-bold" />
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Contacto</label>
                    <input type="text" @bind="_editCenter.Contact" class="w-full h-12 px-4 rounded-xl border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white font-bold" />
                </div>
            </div>
            <button @onclick="SaveCenter" disabled="@_saving" class="w-full h-14 btn-vibrant rounded-2xl font-black text-sm uppercase tracking-widest shadow-green-glow">
                @(_editId > 0 ? "GUARDAR ALTERAÇÕES" : "CRIAR CENTRO")
            </button>
        </div>
    </div>
}

@code {
    private List<SortingCenterDto>? centros;
    private bool _modal = false;
    private bool _saving = false;
    private int _editId = 0;
    private CreateSortingCenterDto _editCenter = new();

    protected override async Task OnInitializedAsync()
    {
        try { centros = await Http.GetFromJsonAsync<List<SortingCenterDto>>("api/gestao-residuos/centros-triagem"); }
        catch { centros = new(); }
    }

    private void EditCenter(SortingCenterDto c)
    {
        _editId = c.Id;
        _editCenter = new() { Name = c.Name, Address = c.Address, Municipality = c.Municipality, CapacityTonsPerDay = c.CapacityTonsPerDay, Contact = c.Contact, Latitude = c.Latitude, Longitude = c.Longitude };
        _modal = true;
    }

    private async Task SaveCenter()
    {
        if (string.IsNullOrWhiteSpace(_editCenter.Name)) { Notification.ShowError("Nome é obrigatório."); return; }
        _saving = true;
        try
        {
            HttpResponseMessage response;
            if (_editId > 0)
                response = await Http.PutAsJsonAsync($"api/gestao-residuos/centros-triagem/{_editId}", _editCenter);
            else
                response = await Http.PostAsJsonAsync("api/gestao-residuos/centros-triagem", _editCenter);

            if (response.IsSuccessStatusCode)
            {
                Notification.ShowSuccess(_editId > 0 ? "Centro atualizado!" : "Centro criado!");
                _modal = false; _editId = 0;
                await OnInitializedAsync();
            }
            else { Notification.ShowError("Erro ao guardar centro."); }
        }
        catch (Exception ex) { Notification.ShowError($"Erro: {ex.Message}"); }
        finally { _saving = false; }
    }
}
