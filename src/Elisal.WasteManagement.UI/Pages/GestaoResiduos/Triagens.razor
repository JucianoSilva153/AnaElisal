@page "/gestao-residuos/triagens"
@inject HttpClient Http
@inject NavigationManager Navigation
@using Elisal.WasteManagement.Application.DTOs
@using Elisal.WasteManagement.Domain.Enums
@inject NotificationService Notification

<PageTitle>SGR Elisal - Triagens</PageTitle>

<div class="p-6 lg:p-10 space-y-8 animate-fade-in">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6">
        <div>
            <h1 class="text-4xl font-black text-slate-900 dark:text-white leading-tight">
                Processo de <span class="text-gradient-green">Triagem</span>
            </h1>
            <p class="text-slate-500 font-medium mt-2">Separação e classificação de materiais por tipo, qualidade e destino.</p>
        </div>
    </div>

    @* ── Lotes de Triagem ── *@
    <div class="bg-white dark:bg-slate-900 rounded-3xl shadow-premium border border-slate-50 dark:border-slate-800 overflow-hidden">
        <div class="px-8 py-6 border-b border-slate-50 dark:border-slate-800 flex items-center justify-between">
            <h2 class="text-lg font-black text-slate-900 dark:text-white">Lotes de Triagem</h2>
            @if (pendentes?.Any() == true)
            {
                <span class="px-3 py-1 bg-amber-50 text-amber-700 rounded-lg text-[10px] font-black uppercase">@pendentes.Count() pendentes</span>
            }
        </div>

        @* ── Recepções Pendentes (iniciar nova triagem) ── *@
        @if (pendentes?.Any() == true)
        {
            <div class="px-8 py-6 bg-amber-50/50 dark:bg-amber-950/20 border-b border-amber-100 dark:border-amber-900/30">
                <p class="text-xs font-black text-amber-700 uppercase tracking-widest mb-4">Recepções Pendentes de Triagem</p>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                    @foreach (var r in pendentes)
                    {
                        <div class="bg-white dark:bg-slate-900 rounded-2xl p-5 border border-amber-100 dark:border-slate-800 flex items-center justify-between">
                            <div>
                                <p class="font-black text-slate-900 dark:text-white">Recepção #@r.Id</p>
                                <p class="text-xs text-slate-500 mt-1">@r.NetWeightKg.ToString("N1") Kg — @r.SortingCenterName</p>
                                <p class="text-[10px] text-slate-400 italic mt-1">@r.DateTime.ToString("dd/MM HH:mm")</p>
                            </div>
                            <button @onclick="() => IniciarTriagem(r.Id)" class="px-4 py-2 bg-primary text-white rounded-xl text-xs font-black uppercase hover:bg-primary/90 transition-all shadow-sm">
                                Iniciar
                            </button>
                        </div>
                    }
                </div>
            </div>
        }

        @* ── Lista de Triagens ── *@
        <div class="divide-y divide-slate-50 dark:divide-slate-800/50">
            @if (triagens == null)
            {
                <div class="px-8 py-12 text-center">
                    <div class="size-8 border-2 border-primary border-t-transparent rounded-full animate-spin mx-auto"></div>
                </div>
            }
            else if (!triagens.Any())
            {
                <div class="px-8 py-20 text-center">
                    <span class="material-symbols-outlined text-slate-200 text-6xl font-light block mb-4">science</span>
                    <p class="text-slate-400 font-bold uppercase tracking-widest text-xs">Sem triagens registadas</p>
                </div>
            }
            else
            {
                @foreach (var t in triagens)
                {
                    <div class="px-8 py-6 hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-colors">
                        <div class="flex items-start justify-between gap-4 mb-4">
                            <div>
                                <div class="flex items-center gap-3">
                                    <span class="text-lg font-black text-slate-900 dark:text-white">Lote #@t.Id</span>
                                    <span class="px-3 py-1 rounded-lg text-[10px] font-black uppercase @GetStatusClass(t.Status)">@t.StatusText</span>
                                </div>
                                <p class="text-xs text-slate-500 mt-1">Recepção #@t.WasteReceptionId — Operador: @t.OperatorName</p>
                                <p class="text-[10px] text-slate-400 italic mt-1">Início: @t.StartDateTime.ToString("dd/MM/yyyy HH:mm") @(t.EndDateTime.HasValue ? $" — Fim: {t.EndDateTime.Value:dd/MM/yyyy HH:mm}" : "")</p>
                            </div>
                            <div class="text-right">
                                <p class="text-2xl font-black text-primary">@t.ApprovalRate.ToString("N1")%</p>
                                <p class="text-[10px] font-black text-slate-400 uppercase">Aproveitamento</p>
                            </div>
                        </div>

                        @* Barra de progresso do peso *@
                        @if (t.ReceptionNetWeightKg > 0)
                        {
                            <div class="mb-4">
                                <div class="flex justify-between text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">
                                    <span>Triado: @t.TotalOutputWeightKg.ToString("N1") Kg</span>
                                    <span>Total: @t.ReceptionNetWeightKg.ToString("N1") Kg</span>
                                </div>
                                <div class="h-2 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                                    <div class="h-full bg-primary rounded-full transition-all" style="width: @(Math.Min(100, (t.TotalOutputWeightKg / t.ReceptionNetWeightKg * 100)).ToString("N0"))%"></div>
                                </div>
                            </div>
                        }

                        @* Outputs *@
                        @if (t.Outputs.Any())
                        {
                            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mt-4">
                                @foreach (var o in t.Outputs)
                                {
                                    <div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-3 flex items-center gap-3">
                                        <div class="size-3 rounded-full flex-shrink-0" style="background-color: @o.WasteTypeColor"></div>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-xs font-black text-slate-900 dark:text-white truncate">@o.WasteTypeName</p>
                                            <p class="text-[10px] text-slate-500">@o.WeightKg.ToString("N1") Kg — @o.QualityGradeText</p>
                                        </div>
                                        <span class="px-2 py-0.5 rounded text-[8px] font-black uppercase @GetDestinationClass(o.DestinationType)">@o.DestinationTypeText</span>
                                    </div>
                                }
                            </div>
                        }

                        @* Adicionar output (se em progresso) *@
                        @if (t.Status == SortingBatchStatus.InProgress)
                        {
                            <div class="mt-4 flex flex-wrap gap-3">
                                <button @onclick="() => ShowAddOutput(t.Id)" class="px-4 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl text-xs font-black text-slate-600 hover:border-primary hover:text-primary transition-all flex items-center gap-2">
                                    <span class="material-symbols-outlined text-sm">add</span> Adicionar Material
                                </button>
                                <button @onclick="() => ConcluirTriagem(t.Id)" class="px-4 py-2 bg-green-600 text-white rounded-xl text-xs font-black hover:bg-green-700 transition-all flex items-center gap-2">
                                    <span class="material-symbols-outlined text-sm">check_circle</span> Concluir Triagem
                                </button>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>
</div>

@* ── Modal Adicionar Output ── *@
@if (_outputModal)
{
    <div class="fixed inset-0 z-[60] bg-slate-900/50 backdrop-blur-sm flex items-center justify-center p-4" @onclick="() => _outputModal = false">
        <div class="bg-white dark:bg-slate-900 rounded-3xl shadow-2xl w-full max-w-lg p-8 space-y-6" @onclick:stopPropagation="true">
            <h2 class="text-xl font-black text-slate-900 dark:text-white">Adicionar Material Triado</h2>
            <div class="space-y-4">
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Tipo de Resíduo</label>
                    <select @bind="newOutput.WasteTypeId" class="w-full h-12 px-4 rounded-xl border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white font-bold">
                        <option value="0">Selecionar...</option>
                        @if (wasteTypes != null) { @foreach (var wt in wasteTypes) { <option value="@wt.Id">@wt.Name</option> } }
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Peso (Kg)</label>
                    <input type="number" step="0.1" @bind="newOutput.WeightKg" class="w-full h-12 px-4 rounded-xl border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white font-bold" />
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Qualidade</label>
                        <select @bind="newOutput.QualityGrade" class="w-full h-12 px-4 rounded-xl border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white font-bold">
                            <option value="@QualityGrade.A">Alta (A)</option>
                            <option value="@QualityGrade.B">Média (B)</option>
                            <option value="@QualityGrade.C">Baixa (C)</option>
                            <option value="@QualityGrade.Rejected">Rejeitado</option>
                        </select>
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Destino</label>
                        <select @bind="newOutput.DestinationType" class="w-full h-12 px-4 rounded-xl border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white font-bold">
                            <option value="@WasteDestinationType.Recycling">Reciclagem</option>
                            <option value="@WasteDestinationType.Composting">Compostagem</option>
                            <option value="@WasteDestinationType.Landfill">Aterro</option>
                            <option value="@WasteDestinationType.Incineration">Incineração</option>
                            <option value="@WasteDestinationType.InternalReuse">Reuso Interno</option>
                            <option value="@WasteDestinationType.HazardousDisposal">Perigosos</option>
                        </select>
                    </div>
                </div>
            </div>
            <button @onclick="SalvarOutput" disabled="@_saving" class="w-full h-14 btn-vibrant rounded-2xl font-black text-sm uppercase tracking-widest shadow-green-glow">
                ADICIONAR
            </button>
        </div>
    </div>
}

@code {
    private List<SortingBatchDto>? triagens;
    private List<WasteReceptionDto>? pendentes;
    private List<WasteTypeDto>? wasteTypes;
    private bool _outputModal = false;
    private bool _saving = false;
    private CreateSortingBatchOutputDto newOutput = new();

    [SupplyParameterFromQuery] public int? recepcaoId { get; set; }

    private bool _autoStarted = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        
        // Auto-iniciar triagem se veio da página de recepções
        if (recepcaoId.HasValue && !_autoStarted && pendentes?.Any(p => p.Id == recepcaoId.Value) == true)
        {
            _autoStarted = true;
            await IniciarTriagem(recepcaoId.Value);
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            wasteTypes = await Http.GetFromJsonAsync<List<WasteTypeDto>>("api/residuos/tipos");
            pendentes = await Http.GetFromJsonAsync<List<WasteReceptionDto>>("api/gestao-residuos/recepcoes/pendentes");

            var now = DateTime.UtcNow;
            triagens = await Http.GetFromJsonAsync<List<SortingBatchDto>>(
                $"api/gestao-residuos/triagens?inicio={now.AddMonths(-3):yyyy-MM-dd}&fim={now:yyyy-MM-dd}");
        }
        catch 
        { 
            triagens ??= new(); 
            pendentes ??= new(); 
        }
    }

    private async Task IniciarTriagem(int receptionId)
    {
        try
        {
            var dto = new CreateSortingBatchDto { WasteReceptionId = receptionId };
            var response = await Http.PostAsJsonAsync("api/gestao-residuos/triagens", dto);
            if (response.IsSuccessStatusCode)
            {
                Notification.ShowSuccess("Triagem iniciada!");
                await LoadDataAsync();
                StateHasChanged();
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                try 
                {
                    var errorMap = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(errorText);
                    Notification.ShowError(errorMap?.GetValueOrDefault("Message") ?? "Erro ao iniciar triagem.");
                }
                catch { Notification.ShowError("Erro ao iniciar triagem: " + response.ReasonPhrase); }
            }
        }
        catch (Exception ex) { Notification.ShowError($"Erro: {ex.Message}"); }
    }

    private void ShowAddOutput(int batchId)
    {
        newOutput = new CreateSortingBatchOutputDto { SortingBatchId = batchId };
        _outputModal = true;
    }

    private async Task SalvarOutput()
    {
        if (newOutput.WasteTypeId == 0) { Notification.ShowError("Selecione um tipo de resíduo."); return; }
        if (newOutput.WeightKg <= 0) { Notification.ShowError("Peso inválido."); return; }

        _saving = true;
        try
        {
            var response = await Http.PostAsJsonAsync($"api/gestao-residuos/triagens/{newOutput.SortingBatchId}/outputs", newOutput);
            if (response.IsSuccessStatusCode)
            {
                Notification.ShowSuccess("Material registado!");
                _outputModal = false;
                await LoadDataAsync();
                StateHasChanged();
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                var msg = "Erro ao registar material";
                try 
                {
                    using var doc = System.Text.Json.JsonDocument.Parse(errorText);
                    if (doc.RootElement.TryGetProperty("message", out var prop)) msg = prop.GetString() ?? msg;
                    else if (doc.RootElement.TryGetProperty("title", out var titleProp)) msg = titleProp.GetString() ?? msg;
                }
                catch { msg = $"{response.ReasonPhrase}: {errorText}"; }
                
                Notification.ShowError(msg);
            }
        }
        catch (Exception ex) { Notification.ShowError($"Erro: {ex.Message}"); }
        finally { _saving = false; }
    }

    private async Task ConcluirTriagem(int batchId)
    {
        try
        {
            var response = await Http.PutAsync($"api/gestao-residuos/triagens/{batchId}/concluir", null);
            if (response.IsSuccessStatusCode) { Notification.ShowSuccess("Triagem concluída!"); await LoadDataAsync(); StateHasChanged(); }
            else 
            { 
                var errorText = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Erro ao concluir triagem: {errorText}");
                Notification.ShowError("Erro ao concluir triagem: " + (errorText.Length < 100 ? errorText : response.ReasonPhrase)); 
            }
        }
        catch (Exception ex) { Notification.ShowError($"Erro: {ex.Message}"); }
    }

    private string GetStatusClass(SortingBatchStatus status) => status switch
    {
        SortingBatchStatus.Pending => "bg-slate-100 text-slate-600",
        SortingBatchStatus.InProgress => "bg-blue-100 text-blue-700",
        SortingBatchStatus.Completed => "bg-green-100 text-green-700",
        SortingBatchStatus.Cancelled => "bg-red-100 text-red-700",
        _ => "bg-slate-100 text-slate-600"
    };

    private string GetDestinationClass(WasteDestinationType dest) => dest switch
    {
        WasteDestinationType.Recycling => "bg-emerald-100 text-emerald-700",
        WasteDestinationType.Composting => "bg-lime-100 text-lime-700",
        WasteDestinationType.Landfill => "bg-red-100 text-red-700",
        WasteDestinationType.Incineration => "bg-orange-100 text-orange-700",
        WasteDestinationType.InternalReuse => "bg-blue-100 text-blue-700",
        WasteDestinationType.HazardousDisposal => "bg-purple-100 text-purple-700",
        _ => "bg-slate-100 text-slate-600"
    };
}
