@page "/gestao-residuos/recepcoes"
@inject HttpClient Http
@using Elisal.WasteManagement.Application.DTOs
@inject NotificationService Notification

<PageTitle>SGR Elisal - Recepções</PageTitle>

<div class="p-6 lg:p-10 space-y-8 animate-fade-in">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6">
        <div>
            <h1 class="text-4xl font-black text-slate-900 dark:text-white leading-tight">
                <span class="text-gradient-green">Recepções</span> de Resíduos
            </h1>
            <p class="text-slate-500 font-medium mt-2">Histórico completo de entrada de materiais nos centros de triagem.</p>
        </div>
    </div>

    @* ── Filtros ── *@
    <div class="bg-white dark:bg-slate-900 p-8 rounded-3xl shadow-premium border border-slate-50 dark:border-slate-800">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
            <div class="space-y-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Data Início</label>
                <input type="date" @bind="startDate" class="w-full h-12 px-4 rounded-xl border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white font-bold transition-all"/>
            </div>
            <div class="space-y-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Data Fim</label>
                <input type="date" @bind="endDate" class="w-full h-12 px-4 rounded-xl border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white font-bold transition-all"/>
            </div>
            <div class="flex items-end">
                <button @onclick="LoadData" class="w-full h-12 bg-slate-900 dark:bg-slate-700 text-white rounded-xl text-sm font-black hover:bg-black transition-all flex items-center justify-center gap-2 shadow-lg uppercase tracking-widest">
                    <span class="material-symbols-outlined text-lg font-bold">search</span> Pesquisar
                </button>
            </div>
        </div>
    </div>

    @* ── Tabela ── *@
    <div class="bg-white dark:bg-slate-900 rounded-3xl shadow-premium border border-slate-50 dark:border-slate-800 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-slate-50 dark:bg-slate-800/50 text-slate-400 text-[10px] font-black uppercase tracking-widest border-b border-slate-100 dark:border-slate-800">
                <tr>
                    <th class="px-8 py-5">ID</th>
                    <th class="px-8 py-5">Data/Hora</th>
                    <th class="px-8 py-5">Centro</th>
                    <th class="px-8 py-5 text-right">Bruto (Kg)</th>
                    <th class="px-8 py-5 text-right">Tara (Kg)</th>
                    <th class="px-8 py-5 text-right">Líquido (Kg)</th>
                    <th class="px-8 py-5">Recebido por</th>
                    <th class="px-8 py-5 text-center">Estado</th>
                </tr>
                </thead>
                <tbody class="divide-y divide-slate-50 dark:divide-slate-800/50 text-sm">
                @if (recepcoes == null)
                {
                    <tr><td colspan="8" class="px-8 py-12 text-center">
                        <div class="size-8 border-2 border-primary border-t-transparent rounded-full animate-spin mx-auto"></div>
                    </td></tr>
                }
                else if (!recepcoes.Any())
                {
                    <tr><td colspan="8" class="px-8 py-20 text-center">
                        <span class="material-symbols-outlined text-slate-200 text-6xl font-light block mb-4">inventory_2</span>
                        <p class="text-slate-400 font-bold uppercase tracking-widest text-xs">Sem recepções no período</p>
                    </td></tr>
                }
                else
                {
                    @foreach (var r in recepcoes)
                    {
                        <tr class="hover:bg-primary-subtle/30 transition-colors">
                            <td class="px-8 py-5 text-slate-400 font-mono font-bold">#@r.Id</td>
                            <td class="px-8 py-5 text-slate-500 font-bold italic">@r.DateTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="px-8 py-5 font-black text-slate-900 dark:text-white uppercase tracking-tight">@r.SortingCenterName</td>
                            <td class="px-8 py-5 text-right text-slate-500">@r.GrossWeightKg.ToString("N1")</td>
                            <td class="px-8 py-5 text-right text-slate-500">@r.TareWeightKg.ToString("N1")</td>
                            <td class="px-8 py-5 text-right font-black text-slate-900 dark:text-white">@r.NetWeightKg.ToString("N1")</td>
                            <td class="px-8 py-5 text-slate-600">@r.ReceivedByUserName</td>
                            <td class="px-8 py-5 text-center">
                                @if (r.IsSorted)
                                {
                                    <span class="px-3 py-1 bg-green-50 text-green-700 rounded-lg text-[10px] font-black uppercase">Triada</span>
                                }
                                else
                                {
                                    <span class="px-3 py-1 bg-amber-50 text-amber-700 rounded-lg text-[10px] font-black uppercase">Pendente</span>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<WasteReceptionDto>? recepcoes;
    private DateTime startDate = DateTime.Today.AddMonths(-1);
    private DateTime endDate = DateTime.Today;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        try
        {
            recepcoes = await Http.GetFromJsonAsync<List<WasteReceptionDto>>($"api/gestao-residuos/recepcoes?inicio={startDate:yyyy-MM-dd}&fim={endDate:yyyy-MM-dd}");
        }
        catch { recepcoes = new(); }
    }
}
