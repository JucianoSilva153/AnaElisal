@page "/gestao-residuos"
@inject HttpClient Http
@using Elisal.WasteManagement.Application.DTOs
@using Elisal.WasteManagement.Domain.Enums
@inject NotificationService Notification
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>SGR Elisal - Gestão de Resíduos</PageTitle>

<div class="p-6 lg:p-10 space-y-8 animate-fade-in">
    @* ── Header ── *@
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6">
        <div>
            <h1 class="text-4xl font-black text-slate-900 dark:text-white leading-tight">
                Gestão de <span class="text-gradient-green">Resíduos Sólidos</span>
            </h1>
            <p class="text-slate-500 font-medium mt-2">Recepção, triagem e classificação de destino dos resíduos recolhidos.</p>
        </div>
        <div class="flex flex-wrap gap-3">
            <a href="/gestao-residuos/indicadores" class="flex items-center gap-2 px-6 py-3 bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 rounded-2xl text-slate-600 dark:text-slate-300 text-sm font-black hover:shadow-premium transition-all">
                <span class="material-symbols-outlined text-lg font-bold">eco</span>
                <span class="hidden sm:inline">INDICADORES</span>
            </a>
            <AuthorizeView Roles="Driver">
                <button @onclick="() => _recepcaoModal = true" class="btn-vibrant px-8 py-3 flex items-center gap-2 shadow-green-glow">
                    <span class="material-symbols-outlined font-bold">add_circle</span>
                    NOVA RECEPÇÃO
                </button>
            </AuthorizeView>
        </div>
    </div>

    @* ── KPI Cards ── *@
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white dark:bg-slate-900 rounded-3xl p-6 shadow-premium border border-slate-50 dark:border-slate-800">
            <div class="flex items-center gap-3 mb-4">
                <div class="size-12 rounded-2xl bg-blue-50 dark:bg-blue-950 flex items-center justify-center">
                    <span class="material-symbols-outlined text-blue-600">scale</span>
                </div>
                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Recepcionado</span>
            </div>
            <p class="text-3xl font-black text-slate-900 dark:text-white">
                @(indicators?.TotalReceivedTons.ToString("N1") ?? "—") <span class="text-sm font-bold text-slate-400">Ton</span>
            </p>
        </div>
        <div class="bg-white dark:bg-slate-900 rounded-3xl p-6 shadow-premium border border-slate-50 dark:border-slate-800">
            <div class="flex items-center gap-3 mb-4">
                <div class="size-12 rounded-2xl bg-green-50 dark:bg-green-950 flex items-center justify-center">
                    <span class="material-symbols-outlined text-green-600">recycling</span>
                </div>
                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Aproveitamento</span>
            </div>
            <p class="text-3xl font-black text-slate-900 dark:text-white">
                @(indicators?.OverallApprovalRate.ToString("N1") ?? "—")<span class="text-sm font-bold text-green-500">%</span>
            </p>
        </div>
        <div class="bg-white dark:bg-slate-900 rounded-3xl p-6 shadow-premium border border-slate-50 dark:border-slate-800">
            <div class="flex items-center gap-3 mb-4">
                <div class="size-12 rounded-2xl bg-emerald-50 dark:bg-emerald-950 flex items-center justify-center">
                    <span class="material-symbols-outlined text-emerald-600">eco</span>
                </div>
                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">CO₂ Evitado</span>
            </div>
            <p class="text-3xl font-black text-slate-900 dark:text-white">
                @(indicators?.Co2AvoidedTons.ToString("N2") ?? "—") <span class="text-sm font-bold text-slate-400">Ton</span>
            </p>
        </div>
        <div class="bg-white dark:bg-slate-900 rounded-3xl p-6 shadow-premium border border-slate-50 dark:border-slate-800">
            <div class="flex items-center gap-3 mb-4">
                <div class="size-12 rounded-2xl bg-amber-50 dark:bg-amber-950 flex items-center justify-center">
                    <span class="material-symbols-outlined text-amber-600">pending_actions</span>
                </div>
                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Pendentes</span>
            </div>
            <p class="text-3xl font-black text-slate-900 dark:text-white">@(indicators?.PendingReceptions.ToString() ?? "—")</p>
            <p class="text-xs text-slate-400 mt-1 font-medium">recepções sem triagem</p>
        </div>
    </div>

    @* ── Distribuição por Destino ── *@
    @if (indicators?.DestinationBreakdown?.Any() == true)
    {
        <div class="bg-white dark:bg-slate-900 rounded-3xl p-8 shadow-premium border border-slate-50 dark:border-slate-800">
            <h2 class="text-lg font-black text-slate-900 dark:text-white mb-6">Distribuição por Destino Final</h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
                @foreach (var dest in indicators.DestinationBreakdown)
                {
                    <div class="bg-slate-50 dark:bg-slate-800 rounded-2xl p-4 text-center">
                        <div class="size-3 rounded-full mx-auto mb-3" style="background-color: @dest.Color"></div>
                        <p class="text-2xl font-black text-slate-900 dark:text-white">@dest.Percentage.ToString("N1")%</p>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mt-1">@dest.Destination</p>
                        <p class="text-xs text-slate-500 mt-1">@dest.WeightTons.ToString("N2") Ton</p>
                    </div>
                }
            </div>
        </div>
    }

    @* ── Rotas a Aguardar Recepção ── *@
    @if (rotasAguardando?.Any() == true)
    {
        <div class="animate-slide-up">
            <div class="flex items-center gap-3 mb-6">
                <span class="material-symbols-outlined text-amber-500">notification_important</span>
                <h2 class="text-lg font-black text-slate-900 dark:text-white uppercase tracking-tight">Rotas a Aguardar Recepção</h2>
                <span class="px-2 py-0.5 bg-amber-100 text-amber-700 rounded-lg text-[10px] font-black">@rotasAguardando.Count</span>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                @foreach (var rota in rotasAguardando)
                {
                    <div class="bg-white dark:bg-slate-900 rounded-3xl p-5 shadow-premium border border-amber-100 dark:border-amber-900/30 hover:border-amber-300 transition-all group">
                        <div class="flex justify-between items-start mb-3">
                            <div class="size-10 rounded-2xl bg-amber-50 dark:bg-amber-950 flex items-center justify-center">
                                <span class="material-symbols-outlined text-amber-600">local_shipping</span>
                            </div>
                            <span class="text-[9px] font-black text-slate-400 uppercase">Chegada: @(rota.EndTime?.ToString("HH:mm") ?? "—")</span>
                        </div>
                        <h3 class="font-black text-slate-900 dark:text-white truncate">@rota.RouteName</h3>
                        <p class="text-xs text-slate-500 mt-1">@rota.DriverName</p>
                        <AuthorizeView Roles="Driver">
                            <button @onclick="() => PrepareReceptionFromRoute(rota)" class="mt-4 w-full py-2.5 bg-amber-500 hover:bg-amber-600 text-white rounded-xl text-[10px] font-black uppercase tracking-widest transition-all shadow-amber-glow">
                                REGISTAR RECEPÇÃO
                            </button>
                        </AuthorizeView>
                    </div>
                }
            </div>
        </div>
    }

    @* ── Recepções Recentes ── *@
    <div class="bg-white dark:bg-slate-900 rounded-3xl shadow-premium border border-slate-50 dark:border-slate-800 overflow-hidden">
        <div class="flex items-center justify-between px-8 py-6 border-b border-slate-50 dark:border-slate-800">
            <h2 class="text-lg font-black text-slate-900 dark:text-white">Recepções Recentes</h2>
            <a href="/gestao-residuos/recepcoes" class="text-primary text-xs font-black uppercase tracking-widest hover:underline">Ver Todas →</a>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-slate-50 dark:bg-slate-800/50 text-slate-400 text-[10px] font-black uppercase tracking-widest border-b border-slate-100 dark:border-slate-800">
                <tr>
                    <th class="px-8 py-4">Data</th>
                    <th class="px-8 py-4">Centro</th>
                    <th class="px-8 py-4 text-right">Peso Líquido</th>
                    <th class="px-8 py-4 text-center">Origem</th>
                    <th class="px-8 py-4 text-center">Triagem</th>
                </tr>
                </thead>
                <tbody class="divide-y divide-slate-50 dark:divide-slate-800/50 text-sm">
                @if (recepcoes == null)
                {
                    <tr>
                        <td colspan="5" class="px-8 py-12 text-center">
                            <div class="flex flex-col items-center gap-3">
                                <div class="size-8 border-2 border-primary border-t-transparent rounded-full animate-spin"></div>
                                <span class="text-slate-400 font-black uppercase tracking-widest text-[10px]">A carregar...</span>
                            </div>
                        </td>
                    </tr>
                }
                else if (!recepcoes.Any())
                {
                    <tr>
                        <td colspan="5" class="px-8 py-20 text-center">
                            <div class="flex flex-col items-center gap-4">
                                <span class="material-symbols-outlined text-slate-200 text-6xl font-light">inventory_2</span>
                                <p class="text-slate-400 font-bold uppercase tracking-widest text-xs">Sem recepções registadas</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var r in recepcoes.Take(10))
                    {
                        <tr class="hover:bg-primary-subtle/30 transition-colors">
                            <td class="px-8 py-4 text-slate-500 font-bold italic">@r.DateTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="px-8 py-4 font-black text-slate-900 dark:text-white uppercase tracking-tight">@r.SortingCenterName</td>
                            <td class="px-8 py-4 text-right font-black text-slate-900 dark:text-white">
                                @r.NetWeightKg.ToString("N1") <span class="text-xs text-slate-400">Kg</span>
                            </td>
                            <td class="px-8 py-4 text-center">
                                @if (r.RouteExecutionId.HasValue)
                                {
                                    <span class="px-3 py-1 bg-blue-50 text-blue-700 rounded-lg text-[10px] font-black uppercase">@r.RouteExecutionName</span>
                                }
                                else
                                {
                                    <span class="px-3 py-1 bg-slate-50 text-slate-500 rounded-lg text-[10px] font-black uppercase">Avulsa</span>
                                }
                            </td>
                            <td class="px-8 py-4 text-center">
                                @if (r.IsSorted)
                                {
                                    <span class="px-3 py-1 bg-green-50 text-green-700 rounded-lg text-[10px] font-black uppercase">Triada</span>
                                }
                                else
                                {
                                    <AuthorizeView Roles="Driver">
                                        <button @onclick="() => StartTriagem(r.Id)" class="px-3 py-1 bg-amber-50 text-amber-700 hover:bg-amber-100 rounded-lg text-[10px] font-black uppercase cursor-pointer transition-all">Pendente</button>
                                    </AuthorizeView>
                                    <AuthorizeView Roles="Admin,Manager">
                                        <span class="px-3 py-1 bg-slate-50 text-slate-500 rounded-lg text-[10px] font-black uppercase">Pendente</span>
                                    </AuthorizeView>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* ── Modal Nova Recepção ── *@
@if (_recepcaoModal)
{
    <div class="fixed inset-0 z-[60] bg-slate-900/50 backdrop-blur-sm flex items-center justify-center p-4" @onclick="() => _recepcaoModal = false">
        <div class="bg-white dark:bg-slate-900 rounded-3xl shadow-2xl w-full max-w-lg p-8 space-y-6" @onclick:stopPropagation="true">
            <div class="flex items-center justify-between">
                <h2 class="text-xl font-black text-slate-900 dark:text-white">Nova Recepção</h2>
                <button @onclick="() => _recepcaoModal = false" class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="space-y-4">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Centro de Triagem</label>
                        <select @bind="newReception.SortingCenterId" class="w-full h-12 px-4 rounded-xl border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white font-bold transition-all">
                            <option value="0">Selecionar...</option>
                            @if (centros != null)
                            {
                                @foreach (var c in centros)
                                {
                                    <option value="@c.Id">@c.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Origem (Rota)</label>
                        <select @bind="newReception.RouteExecutionId" class="w-full h-12 px-4 rounded-xl border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white font-bold transition-all">
                            <option value="">Avulsa / Manual</option>
                            @if (rotasAguardando != null)
                            {
                                @foreach (var r in rotasAguardando)
                                {
                                    <option value="@r.Id">@r.RouteName (@r.DriverName)</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Peso Bruto (Kg)</label>
                        <input type="number" step="0.1" @bind="newReception.GrossWeightKg" class="w-full h-12 px-4 rounded-xl border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white font-bold"/>
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Tara (Kg)</label>
                        <input type="number" step="0.1" @bind="newReception.TareWeightKg" class="w-full h-12 px-4 rounded-xl border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white font-bold"/>
                    </div>
                </div>
                <div class="bg-slate-50 dark:bg-slate-800 rounded-xl p-4 text-center">
                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Peso Líquido</span>
                    <p class="text-2xl font-black text-primary mt-1">@((newReception.GrossWeightKg - newReception.TareWeightKg).ToString("N1")) Kg</p>
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Observações</label>
                    <textarea @bind="newReception.Notes" rows="2" class="w-full px-4 py-3 rounded-xl border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-white font-medium resize-none"></textarea>
                </div>
            </div>
            <button @onclick="SalvarRecepcao" disabled="@_saving" class="w-full h-14 btn-vibrant rounded-2xl font-black text-sm uppercase tracking-widest shadow-green-glow">
                @if (_saving)
                {
                    <span class="size-5 border-2 border-white border-t-transparent rounded-full animate-spin inline-block"></span>
                }
                else
                {
                    <span>REGISTAR RECEPÇÃO</span>
                }
            </button>
        </div>
    </div>
}

@code {
    private EnvironmentalIndicatorsDto? indicators;
    private List<WasteReceptionDto>? recepcoes;
    private List<SortingCenterDto>? centros;
    private List<RouteExecutionSummaryDto>? rotasAguardando;
    private bool _recepcaoModal = false;
    private bool _saving = false;
    private CreateWasteReceptionDto newReception = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var now = DateTime.UtcNow;
            var startOfMonth = new DateTime(now.Year, now.Month, 1).ToString("yyyy-MM-dd");
            var today = now.ToString("yyyy-MM-dd");

            centros = await Http.GetFromJsonAsync<List<SortingCenterDto>>("api/gestao-residuos/centros-triagem");
            indicators = await Http.GetFromJsonAsync<EnvironmentalIndicatorsDto>($"api/gestao-residuos/indicadores?inicio={startOfMonth}&fim={today}");
            recepcoes = await Http.GetFromJsonAsync<List<WasteReceptionDto>>($"api/gestao-residuos/recepcoes?inicio={startOfMonth}&fim={today}");
            rotasAguardando = await Http.GetFromJsonAsync<List<RouteExecutionSummaryDto>>("api/gestao-residuos/rotas-aguardando");
        }
        catch
        {
            recepcoes = new();
            rotasAguardando = new();
        }
    }

    private void PrepareReceptionFromRoute(RouteExecutionSummaryDto route)
    {
        newReception = new CreateWasteReceptionDto
        {
            RouteExecutionId = route.Id,
            Notes = $"Receção proveniente da Rota: {route.RouteName}",
            SortingCenterId = centros?.FirstOrDefault()?.Id ?? 0
        };
        _recepcaoModal = true;
    }

    private async Task SalvarRecepcao()
    {
        if (newReception.SortingCenterId == 0)
        {
            Notification.ShowError("Selecione um centro de triagem.");
            return;
        }

        if (newReception.GrossWeightKg <= 0)
        {
            Notification.ShowError("Peso bruto inválido.");
            return;
        }

        _saving = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/gestao-residuos/recepcoes", newReception);
            if (response.IsSuccessStatusCode)
            {
                Notification.ShowSuccess("Recepção registada com sucesso!");
                _recepcaoModal = false;
                newReception = new();
                await OnInitializedAsync();
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<Dictionary<string, string>>();
                Notification.ShowError(error?["Message"] ?? "Erro ao registar recepção.");
            }
        }
        catch (Exception ex)
        {
            Notification.ShowError($"Erro: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    private void StartTriagem(int receptionId)
    {
        Navigation.NavigateTo($"/gestao-residuos/triagens?recepcaoId={receptionId}");
    }

    [Inject] private NavigationManager Navigation { get; set; } = null!;
}
