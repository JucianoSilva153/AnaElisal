@page "/rotas/{Id:int}/executar"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using Elisal.WasteManagement.Domain.Entities
@using Elisal.WasteManagement.Application.DTOs
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@inject AuthenticationStateProvider AuthStateProvider
@implements IAsyncDisposable

<PageTitle>SGR Elisal - Executar Rota</PageTitle>

<div class="max-w-6xl mx-auto p-8 space-y-6">
    <div class="flex items-center gap-4">
        <button @onclick='() => Navigation.NavigateTo("rotas")' class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg">
            <span class="material-symbols-outlined">arrow_back</span>
        </button>
        <div class="flex-1">
            <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Executar Rota: @route?.Name</h1>
            <p class="text-slate-500 dark:text-slate-400 text-sm">@route?.WeekDay - Horário: @route?.StartTime.ToString("hh\\:mm")</p>
        </div>
        @if (executionId > 0)
        {
            <div class="text-right">
                <p class="text-sm text-slate-500">Progresso</p>
                <p class="text-2xl font-bold text-primary">@processedCount/@pointStatuses.Count</p>
                @if (skippedCount > 0)
                {
                    <p class="text-xs text-amber-500 font-semibold mt-0.5">@skippedCount inacess.</p>
                }
            </div>
        }
    </div>

    @* Banner de sucesso ao finalizar *@
    @if (showSuccess)
    {
        <div class="p-4 rounded-xl bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 flex items-center gap-3 animate-pulse">
            <span class="material-symbols-outlined text-green-600 text-2xl">check_circle</span>
            <div>
                <p class="font-semibold text-green-800 dark:text-green-200">Rota concluída com sucesso!</p>
                <p class="text-sm text-green-600 dark:text-green-400">Rota processada com sucesso. A redirecionar...</p>
            </div>
        </div>
    }

    @* Banner de execução em curso *@
    @if (executionId > 0 && executionStartTime.HasValue && !showSuccess)
    {
        <div class="p-3 rounded-lg bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 flex items-center gap-3">
            <span class="material-symbols-outlined text-blue-600">schedule</span>
            <p class="text-sm text-blue-800 dark:text-blue-200">
                Execução iniciada às <strong>@executionStartTime.Value.ToLocalTime().ToString("HH:mm")</strong> — progresso guardado automaticamente
            </p>
        </div>
    }

    @* Banner de conflito de recolha detectado automaticamente *@
    @if (!string.IsNullOrEmpty(conflictMessage))
    {
        <div class="p-4 rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 flex items-center gap-3">
            <span class="material-symbols-outlined text-amber-500 text-2xl">warning</span>
            <div class="flex-1">
                <p class="font-semibold text-amber-800 dark:text-amber-200 text-sm">@conflictMessage</p>
                <p class="text-xs text-amber-600 dark:text-amber-400 mt-0.5">O ponto foi marcado como inacessível automaticamente pelo sistema.</p>
            </div>
            <button @onclick="() => conflictMessage = string.Empty"
                    class="text-amber-400 hover:text-amber-600 transition-colors">
                <span class="material-symbols-outlined text-base">close</span>
            </button>
        </div>
    }

    @* Erros de API (ex: validação GPS) *@
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="p-4 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 flex items-center gap-3">
            <span class="material-symbols-outlined text-red-500 text-2xl">error</span>
            <div class="flex-1">
                <p class="font-semibold text-red-800 dark:text-red-200 text-sm">@errorMessage</p>
            </div>
            <button @onclick="() => errorMessage = string.Empty"
                    class="text-red-400 hover:text-red-600 transition-colors">
                <span class="material-symbols-outlined text-base">close</span>
            </button>
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Route Map -->
        <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6 flex flex-col shadow-sm">
            <h2 class="text-lg font-bold text-slate-900 dark:text-white mb-4">Rota no Mapa</h2>
            <div class="flex-1 min-h-[400px]">
                @if (collectionPoints != null && collectionPoints.Any())
                {
                    <MapComponent MapId="executionMap" Points="collectionPoints" ShowRoute="true"/>
                }
                else
                {
                    <div class="w-full h-full bg-slate-100 animate-pulse rounded-lg"></div>
                }
            </div>
        </div>

        <!-- Route Points Checklist -->
        <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6 shadow-sm">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-lg font-bold text-slate-900 dark:text-white">Pontos de Recolha</h2>
                @if (executionId == 0)
                {
                    <button @onclick="StartRoute" class="px-4 py-2 bg-primary text-white rounded-lg text-sm font-bold flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">play_arrow</span>
                        Iniciar Jornada
                    </button>
                }
            </div>

            <div class="space-y-3 max-h-[500px] overflow-y-auto pr-2">
                @if (pointStatuses == null || !pointStatuses.Any())
                {
                    <p class="text-slate-500 italic text-center py-8">Carregando pontos da rota...</p>
                }
                else
                {
                    @foreach (var ps in pointStatuses)
                    {
                        var cp = ps.CollectionPoint;
                        <div class="flex items-start gap-3 p-4 rounded-lg @(ps.IsCompleted ? "bg-green-50 dark:bg-green-900/20" : ps.IsSkipped ? "bg-amber-50 dark:bg-amber-900/20" : "bg-slate-50 dark:bg-slate-800") border @(ps.IsCompleted ? "border-green-200 dark:border-green-800" : ps.IsSkipped ? "border-amber-200 dark:border-amber-800" : "border-slate-200 dark:border-slate-700") transition-colors">
                            <div class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center @(ps.IsCompleted ? "bg-green-500 text-white" : ps.IsSkipped ? "bg-amber-500 text-white" : "bg-slate-300 dark:bg-slate-600 text-slate-700 dark:text-slate-300") font-bold transition-colors">
                                @if (ps.IsCompleted)
                                {
                                    <span class="material-symbols-outlined text-sm">check</span>
                                }
                                else if (ps.IsSkipped)
                                {
                                    <span class="material-symbols-outlined text-sm">block</span>
                                }
                                else
                                {
                                    @(pointStatuses.IndexOf(ps) + 1)
                                }
                            </div>
                            <div class="flex-1">
                                <h3 class="font-semibold text-slate-900 dark:text-white">@cp?.Name</h3>
                                <p class="text-sm text-slate-500 dark:text-slate-400">@cp?.Address</p>
                                @if (ps.CompletedAt.HasValue)
                                {
                                    <p class="text-xs text-green-600 dark:text-green-400 mt-1">
                                        Concluído às @ps.CompletedAt.Value.ToLocalTime().ToString("HH:mm")
                                    </p>
                                }
                                @if (ps.IsSkipped)
                                {
                                    <p class="text-xs text-amber-600 dark:text-amber-400 mt-1 flex items-center gap-1">
                                        <span class="material-symbols-outlined text-xs">block</span>
                                        Inacessível@(!string.IsNullOrEmpty(ps.SkipReason) ? $": {ps.SkipReason}" : "")
                                    </p>
                                }
                            </div>
                            <div class="flex flex-col items-center justify-center">
                                 <label class="flex items-center cursor-pointer" title="Marcar como concluído">
                                     <input type="checkbox" checked="@ps.IsCompleted" @onchange="@(e => TogglePoint(ps, (bool)e.Value!))"
                                            disabled="@(executionId == 0 || isUpdating || ps.IsSkipped)"
                                            class="w-5 h-5 text-primary rounded focus:ring-primary disabled:opacity-50"/>
                                 </label>
                            </div>
                        </div>
                    }
                }
            </div>

            @if (executionId > 0 && pointStatuses.Any() && pointStatuses.All(ps => ps.IsCompleted || ps.IsSkipped))
            {
                <button @onclick="FinishRoute" disabled="@isFinishing" class="w-full mt-6 px-6 py-3 bg-green-600 text-white rounded-lg font-semibold hover:bg-green-700 flex items-center justify-center gap-2 disabled:opacity-70 transition-colors">
                    <span class="material-symbols-outlined">@(isFinishing ? "hourglass_empty" : "check_circle")</span>
                    @(isFinishing ? "A finalizar..." : "Finalizar Rota")
                </button>
            }
        </div>
    </div>
</div>

<Elisal.WasteManagement.UI.Components.Modals.RecolhaModal @ref="recolhaModal" OnRecordSaved="OnCollectionSaved" />

@code {
    [Parameter] public int Id { get; set; }

    private Route? route;
    private List<RoutePointExecutionStatus> pointStatuses = new();
    private List<CollectionPoint> collectionPoints = new();
    private int executionId = 0;
    private DateTime? executionStartTime = null;
    private bool isUpdating = false;
    private bool isFinishing = false;
    private bool showSuccess = false;
    private int completedCount => pointStatuses.Count(ps => ps.IsCompleted);
    private int skippedCount  => pointStatuses.Count(ps => ps.IsSkipped);
    private int processedCount => pointStatuses.Count(ps => ps.IsCompleted || ps.IsSkipped);
    private string conflictMessage = string.Empty;
    private string errorMessage = string.Empty;
    private double? currentLat;
    private double? currentLon;
    private Elisal.WasteManagement.UI.Components.Modals.RecolhaModal recolhaModal = null!;
    private RoutePointExecutionStatus? pendingPointStatus;

    private HubConnection? hubConnection;
    private DotNetObjectReference<ExecutarRota>? dotNetRef;
    private int driverId;
    private string driverName = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            driverName = user.Identity.Name ?? "Unknown";
            var idClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (int.TryParse(idClaim, out var id)) driverId = id;
        }

        var apiUrl = Configuration["ApiSettings:BaseUrl"] ?? "https://localhost:7087";
        hubConnection = new HubConnectionBuilder()
            .WithUrl($"{apiUrl}/locationHub")
            .WithAutomaticReconnect()
            .Build();

        await hubConnection.StartAsync();

        // Receber notificação de conflito de recolha em tempo real
        hubConnection.On<PointConflictNotification>("PointMarkedInaccessible", async (notification) =>
        {
            // Filtrar: só processar se for para esta execução
            if (notification.AffectedExecutionId != executionId) return;

            var ps = pointStatuses.FirstOrDefault(
                p => p.CollectionPointId == notification.CollectionPointId);

            if (ps != null && !ps.IsSkipped && !ps.IsCompleted)
            {
                ps.IsSkipped = true;
                ps.SkipReason = notification.Reason;
                conflictMessage = $"⚠️ Conflito detectado: o ponto '{notification.PointName}' já está a ser recolhido por outro motorista.";
                await InvokeAsync(StateHasChanged);
            }
        });

        await LoadData();

        if (executionId > 0 && executionStartTime.HasValue)
        {
            await StartLocationTracking();
        }
    }

    private async Task LoadData()
    {
        try
        {
            route = await Http.GetFromJsonAsync<Route>($"api/rotas/{Id}");

            // Tentar recuperar execução ativa
            try
            {
                var response = await Http.GetAsync($"api/routeexecution/active/{Id}");
                if (response.IsSuccessStatusCode)
                {
                    var active = await response.Content.ReadFromJsonAsync<ActiveExecutionResponse>();
                    if (active != null)
                    {
                        executionId = active.Execution.Id;
                        executionStartTime = active.Execution.StartTime;
                        pointStatuses = active.Points;
                    }
                }
                else
                {
                    // Sem execução activa — carregar lista de pontos sem progresso
                    var points = await Http.GetFromJsonAsync<List<RoutePoint>>($"api/rotas/{Id}/pontos");
                    if (points != null)
                    {
                        pointStatuses = points.OrderBy(p => p.SequenceOrder).Select(p => new RoutePointExecutionStatus
                        {
                            CollectionPointId = p.CollectionPointId,
                            CollectionPoint = p.CollectionPoint,
                            IsCompleted = false
                        }).ToList();
                    }
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Erro ao carregar execução: {ex.Message}");
            }

            if (pointStatuses != null)
            {
                collectionPoints = pointStatuses
                    .Select(ps => ps.CollectionPoint)
                    .Where(cp => cp != null)
                    .ToList()!;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar rota: {ex.Message}");
        }
    }

    private async Task StartRoute()
    {
        var response = await Http.PostAsync($"api/routeexecution/start/{Id}", null);
        if (response.IsSuccessStatusCode)
        {
            var data = await response.Content.ReadFromJsonAsync<RouteExecutionResponseDto>();
            if (data != null)
            {
                executionId = data.ExecutionId;
                executionStartTime = DateTime.UtcNow;
            }

            await LoadData();
            await StartLocationTracking();
        }
    }

    private async Task TogglePoint(RoutePointExecutionStatus ps, bool completed)
    {
        if (isUpdating) return;

        if (completed)
        {
            pendingPointStatus = ps;
            recolhaModal.Show(ps.CollectionPointId);
            return;
        }

        await UpdatePointStatus(ps, false);
    }

    private async Task OnCollectionSaved()
    {
        if (pendingPointStatus != null)
        {
            await UpdatePointStatus(pendingPointStatus, true);
            pendingPointStatus = null;
        }
    }

    private async Task UpdatePointStatus(RoutePointExecutionStatus ps, bool completed)
    {
        isUpdating = true;
        
        ps.IsCompleted = completed;
        if (completed)
        {
            ps.CompletedAt = DateTime.UtcNow;
            ps.IsSkipped = false;
        }
        else
            ps.CompletedAt = null;

        StateHasChanged();

        await Http.PutAsJsonAsync($"api/routeexecution/{executionId}/point", new UpdatePointStatusDto
        {
            CollectionPointId = ps.CollectionPointId,
            IsCompleted = completed,
            IsSkipped = false
        });

        isUpdating = false;
        StateHasChanged();
    }

    private async Task FinishRoute()
    {
        if (isFinishing) return;
        isFinishing = true;
        StateHasChanged();

        var response = await Http.PostAsync($"api/routeexecution/{executionId}/finish", null);
        if (response.IsSuccessStatusCode)
        {
            await StopLocationTracking();
            showSuccess = true;
            StateHasChanged();
            await Task.Delay(2000);
            Navigation.NavigateTo("/rotas");
        }
        else
        {
            isFinishing = false;
            StateHasChanged();
        }
    }

    private async Task StartLocationTracking()
    {
        if (hubConnection?.State == HubConnectionState.Connected)
        {
            dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("locationTracker.startTracking", dotNetRef);
        }
    }

    private async Task StopLocationTracking()
    {
        await JS.InvokeVoidAsync("locationTracker.stopTracking");
        dotNetRef?.Dispose();
    }

    [JSInvokable]
    public async Task OnLocationChanged(double latitude, double longitude)
    {
        currentLat = latitude;
        currentLon = longitude;

        if (hubConnection?.State == HubConnectionState.Connected && executionId > 0)
        {
            var update = new LocationUpdateDto
            {
                RouteExecutionId = executionId,
                DriverId = driverId,
                DriverName = driverName,
                Latitude = latitude,
                Longitude = longitude,
                Timestamp = DateTime.UtcNow
            };
            await hubConnection.SendAsync("UpdateLocation", update);
        }
    }

    public async ValueTask DisposeAsync()
    {
        await StopLocationTracking();
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    private class ActiveExecutionResponse
    {
        public ActiveExecution Execution { get; set; } = null!;
        public List<RoutePointExecutionStatus> Points { get; set; } = new();
    }

    private class ActiveExecution
    {
        public int Id { get; set; }
        public int RouteId { get; set; }
        public DateTime StartTime { get; set; }
        public RouteExecutionStatus Status { get; set; }
    }

    private class PointConflictNotification
    {
        public int AffectedExecutionId { get; set; }
        public int CollectionPointId { get; set; }
        public string PointName { get; set; } = string.Empty;
        public string Reason { get; set; } = string.Empty;
    }

}
